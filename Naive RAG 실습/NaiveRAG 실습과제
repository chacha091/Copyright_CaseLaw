ntextRecall(),\n","        Faithfulness(),\n","        FactualCorrectness(),\n","    ],\n","    llm=evaluator_llm,\n",")\n","\n","ragas_df = ragas_result.to_pandas()\n","ragas_df.head()"],"metadata":{"id":"UeUpHs8k6Rod"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["metric_columns = [\"context_recall\", \"faithfulness\", \"factual_correctness(mode=f1)\"]\n","\n","available_metric_columns = [col for col in metric_columns if col in ragas_df.columns]\n","\n","ragas_summary = ragas_df[available_metric_columns].mean()\n","\n","for metric, score in ragas_summary.items():\n","    print(f\"{metric}: {score:.4f}\")"],"metadata":{"id":"AG_-jhQ-6Su6"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["ragas_df[[\"user_input\", *available_metric_columns]].head(eval_sample_size)"],"metadata":{"id":"JZ6u6cmq6hiT","executionInfo":{"status":"aborted","timestamp":1773144292537,"user_tz":-540,"elapsed":4,"user":{"displayName":"차현주","userId":"11758505755300206446"}}},"execution_count":null,"outputs":[]}]}